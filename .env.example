# Copiar pra .env e preencher

# 1) Criar bot via @BotFather no Telegram, comando /newbot
# 2) Pegar o token retornado e colar aqui:
TELEGRAM_TOKEN=

# 3) Mandar uma mensagem qualquer pro seu bot (procurar pelo @nome)
# 4) Acessar https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
# 5) Pegar o "id" do chat (número, geralmente positivo se for chat privado)
TELEGRAM_CHAT_ID=
